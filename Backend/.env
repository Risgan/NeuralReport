# App
APP_NAME=NeuralReport
APP_VERSION=1.0.0
DEBUG=true
APP_NAME=NeuralReport API
APP_ENV=dev
APP_PORT=8000


# Base de datos
DB_HOST=localhost
# DB_HOST=127.0.0.1
DB_PORT=5444
DB_NAME=NeuralReport
